{
    "name": "xoopress/xoopress",
    "description": "A modular CMS combining XOOPS and WordPress concepts",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "XooPress Team",
            "email": "team@xoopress.org"
        }
    ],
    "require": {
        "php": "^8.2",
        "filp/whoops": "^2.16",
        "ext-pdo": "*",
        "ext-gettext": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "XooPress\\": "app/",
            "XooPress\\Modules\\": "modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "XooPress\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {}
}